# Supabase Postgres connection string
# Supabase dashboard → Connect → Direct → Session pooler (URI). SSL is required
# and added automatically by db.py.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Environment
ENVIRONMENT=development

# Auth / JWT
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@supplier.com
ADMIN_PASSWORD=change-me

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Sentry (optional)
SENTRY_DSN=

# Logging level
LOG_LEVEL=INFO
